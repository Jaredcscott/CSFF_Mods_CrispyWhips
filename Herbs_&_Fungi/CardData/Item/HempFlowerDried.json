        "LocalizationKey": "Herbs_And_Fungus_HempFlowerDried_CardDescription",
        "DefaultText": "Dried flowering tops with psychoactive properties. Can be ground into powder or burned on fires to create aromatic smoke with mood-enhancing effects."
    },
    "CardHelpSection": {
        "ParentObjectID": "herbs_fungi_hemp_flower_dried",
        "LocalizationKey": "Herbs_And_Fungus_HempFlowerDried_CardHelpSection",
