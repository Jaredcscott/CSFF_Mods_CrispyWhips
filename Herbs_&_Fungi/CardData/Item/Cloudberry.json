    },
    "CardDescription": {
        "LocalizationKey": "herbs_fungi_cloudberry_CardDescription",
        "DefaultText": "Rare golden-orange berries that grow only in the coldest northern bogs and meadows. Sweet, soft, and highly prized as a delicacy."
    },
    "CardHelpSection": {
        "LocalizationKey": "herbs_fungi_cloudberry_CardHelpSection",
        "DefaultText": "<b>Season:</b> Late Summer\n\n<b>Found:</b> Northern regions, pine meadows only.\n\n<b>Uses:</b> Eat raw, dry for long-term storage, or ferment.\n\n<b>Benefits:</b> Excellent nutrition. Rare and rewarding find."
    },
