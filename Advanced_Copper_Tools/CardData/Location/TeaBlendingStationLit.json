    "DefaultText": "Tea Station (Lit)"
  },
  "CardDescription": {
    "ParentObjectID": "advanced_copper_tools_tea_blending_station_lit",
    "LocalizationKey": "Advanced_Copper_Tools_TeaBlendingStation_Lit_CardDescription",
    "DefaultText": "A lit tea station. The stove burns steadily, heating the built-in water tank. Fresh herbs in the six slots dry rapidly. Drag a water container or shallow water source to add a Water Charge; drag an empty clay bowl to draw boiled water once Water Temp reaches 50%. Fire will go out when fuel runs empty."
  },
  "CanBeRenamed": false,
  "AlternateNames": [],
  "LiquidSuffixName": {
