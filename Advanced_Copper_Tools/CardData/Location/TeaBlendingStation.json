{
  "UniqueID": "advanced_copper_tools_tea_blending_station",
  "CardName": {
    "ParentObjectID": "advanced_copper_tools_tea_blending_station",
    "LocalizationKey": "Advanced_Copper_Tools_TeaBlendingStation_CardName",
    "DefaultText": "Tea Station"
  },
  "CardDescription": {
    "ParentObjectID": "advanced_copper_tools_tea_blending_station",
    "LocalizationKey": "Advanced_Copper_Tools_TeaBlendingStation_CardDescription",
    "DefaultText": "A dedicated workbench with six herb-and-grinding slots, a built-in water tank (8 bowls capacity, tracked as Water Charges), and a copper stove. Drag a water container or shallow water source (river, pond) to add a charge. Light the stove to heat the water and speed up herb drying."
  },
  "CanBeRenamed": false,
  "AlternateNames": [],
  "LiquidSuffixName": {
    "ParentObjectID": "advanced_copper_tools_tea_blending_station",
